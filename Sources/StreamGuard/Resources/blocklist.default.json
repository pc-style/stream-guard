{
  "phrases": [
    { "text": "example-banned-term", "fuzzy": true },
    { "text": "exact-ban", "fuzzy": false },
    { "text": "bad phrase", "fuzzy": false },
    { "text": "secret example test", "fuzzy": true },
    { "text": "private stream notes", "fuzzy": false }
  ],
  "patterns": {
    "phone": true,
    "email": true,
    "ssn": false,
    "secrets": true,
    "cards": false,
    "nationalIDs": false
  },
  "hysteresis": {
    "triggerFrames": 1,
    "clearFrames": 3
  },
  "ocr": {
    "fps": 6,
    "recognitionLevel": "fast",
    "minimumTextHeight": 0.01
  },
  "filtering": {
    "mode": "blacklist",
    "blurAllMinimumCharacters": 2,
    "whitelist": [
      { "text": "support@example.com", "fuzzy": true, "minimumSimilarity": 0.92 },
      { "text": "public demo", "fuzzy": true, "minimumSimilarity": 0.88 },
      { "text": "sample customer", "fuzzy": true, "minimumSimilarity": 0.86 }
    ],
    "blacklist": [
      { "text": "private@example.com", "fuzzy": true, "minimumSimilarity": 0.9 },
      { "text": "private stream notes", "fuzzy": true, "minimumSimilarity": 0.86 },
      { "text": "launch payroll", "fuzzy": true, "minimumSimilarity": 0.84 }
    ]
  },
  "pipeline": {
    "mode": "roiCascade",
    "yodoShowsMasks": true
  },
  "obs": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 4455,
    "controlMode": "source",
    "blackoutScene": "BLACKOUT",
    "protectedScene": "STREAM_GUARD_PROTECTED",
    "blackoutSource": "STREAM_GUARD_BLACKOUT"
  },
  "userSettings": {
    "protectionMode": "both",
    "sensitivity": "safe",
    "sensitiveText": [],
    "safeText": [],
    "enableSecrets": true,
    "enableCards": false,
    "enableNationalIDs": false
  }
}
